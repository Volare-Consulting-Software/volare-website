---
interface Props {
  name: string;
  title: string;
  location: string;
  initials: string;
  photo?: string | null;
  bio: string;
  linkedin?: string;
}
const { name, title, location, initials, photo, bio, linkedin } = Astro.props;
---

<article class="rounded-2xl border border-[var(--border)] bg-[var(--bg-raised)] p-7 md:p-9 grid gap-7 md:grid-cols-[auto_1fr] md:items-start">
  <div class="flex md:block">
    {
      photo ? (
        <img
          src={photo}
          alt={name}
          width="120"
          height="120"
          class="block w-28 h-28 md:w-32 md:h-32 rounded-full object-cover border border-[var(--border)]"
        />
      ) : (
        <div
          class="flex items-center justify-center w-28 h-28 md:w-32 md:h-32 rounded-full bg-[color:var(--color-primary)] text-white font-extrabold tracking-tight"
          style="font-size: 2.75rem; letter-spacing: -0.02em;"
          aria-hidden="true"
        >
          {initials}
        </div>
      )
    }
  </div>
  <div>
    <div class="text-eyebrow">{title}</div>
    <h3 class="text-h3 mt-1">{name}</h3>
    <div class="text-[var(--text-muted)] text-sm mt-1">{location}</div>
    <p class="text-[var(--text)] mt-5 leading-relaxed">{bio}</p>
    {
      linkedin && (
        <a
          href={linkedin}
          rel="noopener noreferrer"
          target="_blank"
          class="inline-flex items-center gap-2 mt-6 font-semibold text-[color:var(--color-primary)] hover:underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          View on LinkedIn
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17 17 7M9 7h8v8" />
          </svg>
        </a>
      )
    }
  </div>
</article>
