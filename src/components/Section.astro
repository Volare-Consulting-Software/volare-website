---
interface Props {
  id?: string;
  tone?: "default" | "raised" | "sunken";
  spacing?: "default" | "tight" | "loose";
  class?: string;
}
const { id, tone = "default", spacing = "default", class: className = "" } = Astro.props;

const bg =
  tone === "raised"
    ? "bg-[var(--bg-raised)]"
    : tone === "sunken"
      ? "bg-[var(--bg-sunken)]"
      : "bg-[var(--bg)]";

const pad =
  spacing === "tight"
    ? "py-12 md:py-16"
    : spacing === "loose"
      ? "py-24 md:py-36"
      : "py-16 md:py-24";
---

<section id={id} class={`relative ${bg} ${pad} ${className}`}>
  <div class="container-page">
    <slot />
  </div>
</section>
