---
import CTAButton from "./CTAButton.astro";
---

<section class="relative overflow-hidden">
  <div class="container-page pt-20 pb-16 md:pt-28 md:pb-24">
    <div class="max-w-3xl">
      <p class="kp-eyebrow text-eyebrow">Volare presents</p>
      <h1 class="kp-headline text-display mt-5" transition:name="hero-headline">
        Introducing Pilota.
      </h1>
      <p class="kp-subhead text-lg md:text-xl text-[var(--text)] mt-6 max-w-2xl leading-snug">
        An AI engine with humans at every gate. It's how we ship software fast — without the slop.
      </p>
      <div class="kp-cta mt-10 flex flex-col sm:flex-row gap-3">
        <CTAButton href="/pilota" variant="primary" size="large">
          See Pilota
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </CTAButton>
        <CTAButton href="#believe" variant="ghost" size="large">
          What we believe
        </CTAButton>
      </div>
    </div>
  </div>

</section>

<style>
  .kp-eyebrow {
    opacity: 0;
    transform: translateY(12px);
    animation: kp-rise 480ms cubic-bezier(0.2, 0.7, 0.2, 1) 80ms forwards;
  }

  .kp-headline {
    opacity: 0;
    transform: translateY(12px);
    letter-spacing: -0.005em;
    animation:
      kp-rise 600ms cubic-bezier(0.2, 0.7, 0.2, 1) 200ms forwards,
      kp-tighten 700ms cubic-bezier(0.2, 0.7, 0.2, 1) 200ms forwards;
  }

  .kp-subhead {
    opacity: 0;
    transform: translateY(12px);
    animation: kp-rise 480ms cubic-bezier(0.2, 0.7, 0.2, 1) 360ms forwards;
  }

  .kp-cta {
    opacity: 0;
    transform: translateY(12px);
    animation: kp-rise 480ms cubic-bezier(0.2, 0.7, 0.2, 1) 480ms forwards;
  }

  .kp-scroll-cue {
    opacity: 0;
    animation: kp-fade 600ms ease-out 900ms forwards;
  }

  @keyframes kp-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes kp-tighten {
    to {
      letter-spacing: -0.02em;
    }
  }

  @keyframes kp-fade {
    to {
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kp-eyebrow,
    .kp-headline,
    .kp-subhead,
    .kp-cta,
    .kp-scroll-cue {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
    .kp-headline {
      letter-spacing: -0.02em;
    }
    .kp-scroll-cue {
      opacity: 0.7;
    }
  }
</style>
