---
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = "" } = Astro.props;
---

<span
  class={`inline-flex items-center justify-center rounded-full bg-[var(--primary-tint)] text-[color:var(--color-primary)] ${className}`}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <slot />
</span>
