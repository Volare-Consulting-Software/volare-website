---
---

<dialog
  id="engagement-modal"
  class="engagement-modal"
  aria-labelledby="engagement-title"
>
  <div class="engagement-card" role="document">
    <header class="engagement-header">
      <div>
        <p class="text-eyebrow">Start an engagement</p>
        <h2 id="engagement-title" class="text-h2 mt-2">Tell us what you're building.</h2>
      </div>
      <button
        type="button"
        id="engagement-close"
        class="engagement-close"
        aria-label="Close"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
    </header>

    <p class="text-[var(--text-muted)] mt-3">
      A short note is enough. We'll review and reply directly.
    </p>

    <form id="engagement-form" class="engagement-form" novalidate>
      <div class="engagement-row">
        <label class="engagement-field">
          <span>Name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="engagement-field">
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>

      <label class="engagement-field">
        <span>Company <span class="text-[var(--text-muted)]">(optional)</span></span>
        <input type="text" name="company" autocomplete="organization" />
      </label>

      <label class="engagement-field">
        <span>What are you working on?</span>
        <textarea name="message" rows="5" required></textarea>
      </label>

      <!-- Honeypot — must remain empty. Real users never see this. -->
      <input type="text" name="company_website" class="engagement-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <p
        id="engagement-status"
        class="engagement-status"
        role="status"
        aria-live="polite"
      ></p>

      <div class="engagement-actions">
        <button type="submit" class="engagement-submit">
          <span class="engagement-submit-label">Send</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </form>
  </div>
</dialog>

<style>
  .engagement-modal {
    border: none;
    padding: 0;
    background: transparent;
    width: min(640px, 92vw);
    color: inherit;
    margin: auto;
  }
  .engagement-modal::backdrop {
    background: rgba(15, 15, 17, 0.65);
    backdrop-filter: blur(4px);
  }

  .engagement-card {
    background: var(--bg-raised);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: clamp(1.5rem, 4vw, 2rem);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      0 8px 32px rgba(0, 0, 0, 0.18);
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
  }

  .engagement-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .engagement-close {
    flex-shrink: 0;
    inline-size: 40px;
    block-size: 40px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 150ms ease;
  }
  .engagement-close:hover {
    border-color: var(--border-strong);
  }

  .engagement-form {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .engagement-row {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 600px) {
    .engagement-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .engagement-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .engagement-field > span {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-strong);
  }
  .engagement-field input,
  .engagement-field textarea {
    appearance: none;
    width: 100%;
    background: var(--bg);
    color: var(--text-strong);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.7rem 0.85rem;
    font: inherit;
    line-height: 1.4;
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }
  .engagement-field textarea {
    resize: vertical;
    min-height: 8rem;
  }
  .engagement-field input:focus,
  .engagement-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-tint);
  }

  .engagement-honeypot {
    position: absolute !important;
    left: -10000px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .engagement-status {
    margin: 0;
    font-size: 0.9rem;
    min-height: 1.4em;
  }
  .engagement-status[data-tone="success"] { color: var(--color-success); }
  .engagement-status[data-tone="error"] { color: var(--color-error); }

  .engagement-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }
  .engagement-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 48px;
    padding: 0 1.25rem;
    border-radius: 8px;
    background: var(--color-primary);
    color: white;
    border: none;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .engagement-submit:hover { background: var(--color-primary-hover); }
  .engagement-submit:active { background: var(--color-primary-pressed); }
  .engagement-submit[disabled] {
    opacity: 0.6;
    cursor: progress;
  }
</style>

<script>
  function setupEngagementModal() {
    const modal = document.getElementById("engagement-modal") as HTMLDialogElement | null;
    if (!modal || modal.dataset.bound === "true") return;
    modal.dataset.bound = "true";

    const form = modal.querySelector("#engagement-form") as HTMLFormElement;
    const closeBtn = modal.querySelector("#engagement-close") as HTMLButtonElement;
    const status = modal.querySelector("#engagement-status") as HTMLElement;
    const submit = form.querySelector(".engagement-submit") as HTMLButtonElement;
    const submitLabel = form.querySelector(".engagement-submit-label") as HTMLElement;

    const open = () => {
      status.textContent = "";
      status.removeAttribute("data-tone");
      modal.showModal();
      // Focus the first field for keyboard users
      const firstInput = form.querySelector('input[name="name"]') as HTMLInputElement | null;
      requestAnimationFrame(() => firstInput?.focus());
    };

    const close = () => {
      if (modal.open) modal.close();
    };

    closeBtn.addEventListener("click", close);

    // Click-outside-card closes
    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });

    // Global click capture for any link/button with href="#engage" or [data-engage]
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const trigger = target.closest('a[href="#engage"], [data-engage]') as HTMLElement | null;
      if (!trigger) return;
      e.preventDefault();
      open();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      status.removeAttribute("data-tone");

      const formData = new FormData(form);

      // Honeypot check — bots fill every field; real users leave this blank.
      if ((formData.get("company_website") as string)?.length) {
        // Pretend success — don't tip off the bot.
        status.dataset.tone = "success";
        status.textContent = "Thanks. Your message is on its way.";
        form.reset();
        return;
      }

      const payload = {
        name: (formData.get("name") as string).trim(),
        email: (formData.get("email") as string).trim(),
        company: (formData.get("company") as string)?.trim() || "",
        message: (formData.get("message") as string).trim(),
      };

      if (!payload.name || !payload.email || !payload.message) {
        status.dataset.tone = "error";
        status.textContent = "Please fill in your name, email, and a short note.";
        return;
      }

      submit.disabled = true;
      submitLabel.textContent = "Sending…";

      try {
        if (import.meta.env.DEV) {
          // Dev-only: simulate the round-trip without hitting the (yet-to-be-deployed) function.
          console.log("[engagement-form / dev]", payload);
          await new Promise((r) => setTimeout(r, 600));
        } else {
          const res = await fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            throw new Error(body?.error || `Request failed (${res.status})`);
          }
        }

        status.dataset.tone = "success";
        status.textContent = "Thanks. Your message is on its way.";
        form.reset();
      } catch (err) {
        status.dataset.tone = "error";
        status.textContent =
          err instanceof Error
            ? err.message
            : "Something went wrong. Please try again in a moment.";
      } finally {
        submit.disabled = false;
        submitLabel.textContent = "Send";
      }
    });
  }

  setupEngagementModal();
  document.addEventListener("astro:after-swap", setupEngagementModal);
</script>
