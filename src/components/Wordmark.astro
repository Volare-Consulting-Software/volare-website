---
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${className}`} transition:name="wordmark">
  <img
    src="/logo-icon.png"
    alt=""
    width={size}
    height={size}
    class="block dark:hidden"
    aria-hidden="true"
  />
  <img
    src="/logo-icon-inverse.png"
    alt=""
    width={size}
    height={size}
    class="hidden dark:block"
    aria-hidden="true"
  />
  <span
    class="font-extrabold tracking-tight text-[color:var(--text-strong)] lowercase"
    style={`font-size: ${Math.round(size * 0.78)}px; letter-spacing: -0.02em;`}
  >
    volare
  </span>
</span>
