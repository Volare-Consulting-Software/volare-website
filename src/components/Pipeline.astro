---
import Stage from "./Stage.astro";

interface StageItem {
  title: string;
  body: string;
}

interface Props {
  stages: StageItem[];
}

const { stages } = Astro.props;
---

<ol class="list-none p-0 m-0">
  {
    stages.map((s, i) => (
      <Stage
        index={i}
        total={stages.length}
        title={s.title}
        body={s.body}
        delay={i * 80}
      />
    ))
  }
</ol>
